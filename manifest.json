{
  "name": "Audio Experience Lab for SoundCloud",
  "version": "0.1.0",
  "manifest_version": 3,
  "description": "Experimental UX overhaul for SoundCloud.",
  "background": {
    "service_worker": "src/background/background.js"
  },
  "permissions": ["activeTab"],
  "host_permissions": ["https://soundcloud.com/*"],
  "web_accessible_resources": [
    {
      "matches": [
        "*://soundcloud.com/*"
      ],
      "resources": [
        "src/content/css/*.css"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://soundcloud.com/*"],
      "js": ["src/content/index.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    }
  ]
}